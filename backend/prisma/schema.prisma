// 物流員工管理系統 - 資料庫 Schema
// 開發階段使用 SQLite，正式環境可改為 PostgreSQL (僅需調整 datasource provider)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// 帳號 / 角色
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  MANAGER
  REGION_MANAGER
  EMPLOYEE
}

// 特殊職稱：執行長 / 特殊，不參與每月自動職稱判定，單價固定
enum SpecialTitle {
  CEO // 執行長
  SPECIAL // 特殊
}

// 一般員工職稱大類（每月自動判定，可由管理者手動覆蓋）
enum TitleCategory {
  SENIOR // 資深員工 (當月出勤 >= 20 天)
  STAFF // 員工 (當月出勤 > 10 天 且 < 20 天)
  TEMP // 臨時工 (當月出勤 <= 10 天)
}

// 日平均件數高/低（僅資深員工、員工適用）
enum TitleLevel {
  HIGH
  LOW
}

// 車輛類型：機車 / 貨車，決定預設保養項目
enum VehicleType {
  MOTORCYCLE // 機車
  TRUCK // 貨車
}

// 每日司機／隨車人員角色
enum DailyRoleType {
  NONE // 無
  TRUCK_DRIVER // 貨車司機
  TRUCK_ATTENDANT // 貨車隨車人員
}

// 請假申請審核狀態
enum LeaveStatus {
  PENDING // 待審核
  APPROVED // 已核准
  REJECTED // 已拒絕
}

// 加油回報審核狀態
enum FuelReportStatus {
  PENDING // 待審核
  APPROVED // 已核准
  REJECTED // 已駁回
}

// 停車費回報審核狀態
enum ParkingFeeReportStatus {
  PENDING // 待審核
  APPROVED // 已核准
  REJECTED // 已駁回
}

// 車輛故障報修處理狀態
enum RepairRequestStatus {
  PENDING // 待處理
  IN_PROGRESS // 處理中
  DONE // 已完成
  CANCELLED // 已取消／駁回
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String
  name         String
  role         Role    @default(EMPLOYEE)
  isActive     Boolean @default(true)

  // 特殊職稱（執行長/特殊），由管理者指派，null 表示一般員工，參與自動判定
  specialTitle SpecialTitle?

  // 固定每月職務加給（舊版逐人填寫，已由 JobPosition 取代，保留欄位避免破壞歷史資料）
  monthlyAllowance Float @default(0)

  // 職務（單選）：決定固定職務加給金額與可使用的模組權限（capabilities）
  jobPositionId String?
  jobPosition   JobPosition? @relation(fields: [jobPositionId], references: [id])
  // 任職起始日：職務加給自此日所屬月份起生效；此日之前的月份不計入加給（避免回算歷史薪資）
  jobPositionSince DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveryRecords           DeliveryRecord[]
  mileageRecords            MileageRecord[]
  titleOverrides            EmployeeTitleOverride[]
  salaryDeductions          SalaryDeduction[]
  dailyRoles                DailyRoleRecord[]
  leaveRequests             LeaveRequest[]
  regionMemberships         RegionMember[]
  schedulesAsEmployee       Schedule[]              @relation("ScheduleEmployee")
  schedulesCreated          Schedule[]              @relation("ScheduleCreator")
  fuelReports               FuelReport[]            @relation("FuelReportEmployee")
  fuelReportsReviewed       FuelReport[]            @relation("FuelReportReviewer")
  parkingFeeReports         ParkingFeeReport[]      @relation("ParkingFeeReportEmployee")
  parkingFeeReportsReviewed ParkingFeeReport[]      @relation("ParkingFeeReportReviewer")
  maintenanceLogsCreated    MaintenanceLog[]        @relation("MaintenanceLogCreator")
  repairRequestsReported    RepairRequest[]         @relation("RepairReporter")
  repairRequestsHandled     RepairRequest[]         @relation("RepairHandler")
}

// ---------------------------------------------------------------------------
// 職務：固定職務加給 ＋ 模組權限（與「特殊職稱」論件計酬為獨立兩套，互不影響）
// 例：車輛管理組長（加給＋解鎖車輛管理）、人員運能組長（加給＋解鎖排班）
// ---------------------------------------------------------------------------

model JobPosition {
  id           String  @id @default(cuid())
  name         String // 職務名稱（車輛管理組長／人員運能組長…）
  allowance    Float   @default(0) // 固定月加給金額，無條件加總，不綁出勤/件數
  capabilities Json    @default("[]") // 此職務解鎖的模組權限鍵陣列，例：["MANAGE_VEHICLES"]
  isActive     Boolean @default(true) // 軟停用：停用後不發加給、不授權、不出現於指派下拉
  sortOrder    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members User[]
}

// ---------------------------------------------------------------------------
// 模組一：每日送件記錄
// ---------------------------------------------------------------------------

model DeliveryRecord {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  date         DateTime // 僅取日期部分使用
  forwardCount Int      @default(0) // 正物流件數
  reverseCount Int      @default(0) // 逆物流件數
  note         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

// ---------------------------------------------------------------------------
// 模組二：車輛里程記錄
// ---------------------------------------------------------------------------

model MileageRecord {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  vehicleId  String
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id])
  date       DateTime
  endMileage Float // 當日結束里程（累計里程）
  // distance (當日行駛里程) = endMileage - 同車輛前一筆紀錄的 endMileage，由應用層計算，不於此儲存

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date, vehicleId])
  @@index([vehicleId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// 模組三 B：每日司機／隨車人員角色紀錄（員工自填，管理者可覆蓋）
// ---------------------------------------------------------------------------

model DailyRoleRecord {
  id     String        @id @default(cuid())
  userId String
  user   User          @relation(fields: [userId], references: [id])
  date   DateTime
  role   DailyRoleType @default(NONE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

// ---------------------------------------------------------------------------
// 模組三 A：員工每月職稱覆蓋（管理者手動調整，覆蓋自動判定結果）
// ---------------------------------------------------------------------------

model EmployeeTitleOverride {
  id       String        @id @default(cuid())
  userId   String
  user     User          @relation(fields: [userId], references: [id])
  year     Int
  month    Int // 1-12
  category TitleCategory
  level    TitleLevel? // SENIOR / STAFF 適用，TEMP 不適用

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, year, month])
}

// ---------------------------------------------------------------------------
// 模組五：基礎設定 - 車輛管理 / 保養提醒
// ---------------------------------------------------------------------------

model Vehicle {
  id             String      @id @default(cuid())
  plateNumber    String      @unique
  type           VehicleType @default(TRUCK) // 機車 / 貨車
  note           String? // 備註
  isActive       Boolean     @default(true)
  currentMileage Float       @default(0) // 目前累計里程，可由管理者修正

  // 證件 / 稅務到期日（選填，供到期提醒使用）
  insuranceCompulsoryExpiry DateTime? // 強制險到期日
  insuranceLiabilityExpiry  DateTime? // 第三人責任險（任意險）到期日
  inspectionExpiry          DateTime? // 下次驗車到期日
  licenseTaxDueDate         DateTime? // 牌照稅應繳日
  fuelTaxDueDate            DateTime? // 燃料稅應繳日

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mileageRecords    MileageRecord[]
  maintenanceItems  VehicleMaintenanceItem[]
  maintenanceLogs   MaintenanceLog[]
  repairRequests    RepairRequest[]
  fuelReports       FuelReport[]
  parkingFeeReports ParkingFeeReport[]
}

// 車輛保養項目：依車型設定不同更換週期，記錄上次更換里程與備註
model VehicleMaintenanceItem {
  id                String    @id @default(cuid())
  vehicleId         String
  vehicle           Vehicle   @relation(fields: [vehicleId], references: [id])
  itemName          String // 保養項目名稱（機油 / 齒輪油 / 空氣濾芯 / 皮帶...）
  intervalKm        Float // 更換週期（公里）
  intervalDays      Int? // 更換週期（天數，選填；與里程先到先提醒）
  lastChangeMileage Float     @default(0) // 上次更換時的累計里程
  lastChangeNote    String? // 上次更換備註（記錄做了什麼）
  lastChangeAt      DateTime? // 上次更換時間

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vehicleId])
}

// 車輛維修保養履歷：每次登記維修或完成報修都寫入一筆永久紀錄（含費用）
model MaintenanceLog {
  id        String   @id @default(cuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  date      DateTime // 維修／保養日期
  mileage   Float    @default(0) // 當時累計里程
  itemName  String // 維修／保養項目
  cost      Float    @default(0) // 費用
  vendor    String? // 廠商／技師
  note      String? // 備註

  createdById String?
  createdBy   User?   @relation("MaintenanceLogCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vehicleId])
  @@index([date])
}

// 車輛故障報修：員工回報異常，管理者排修並標記完成
model RepairRequest {
  id          String              @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle             @relation(fields: [vehicleId], references: [id])
  description String // 故障描述
  status      RepairRequestStatus @default(PENDING)

  reportedById String
  reportedBy   User   @relation("RepairReporter", fields: [reportedById], references: [id])

  handledById String?
  handledBy   User?     @relation("RepairHandler", fields: [handledById], references: [id])
  handledAt   DateTime?
  resolveNote String? // 處理／完成備註

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vehicleId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// 模組五：基礎設定 - 薪資參數設定 (singleton, id 固定為 1)
// ---------------------------------------------------------------------------

model SalarySettings {
  id                  Int     @id @default(1)
  driverBonus         Float   @default(1000) // 司機每日加給
  attendantBonus      Float   @default(500) // 隨車人員每日加給
  registrationEnabled Boolean @default(true) // 是否開放員工自行註冊帳號

  // 薪資封存寬限日：次月第 N 日後若上月仍未封存，儀表板提醒（不會自動封存）
  salaryLockGraceDay Int @default(5)

  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// 模組五：薪資扣項 - 管理者為員工登記某月份的扣薪事項
// ---------------------------------------------------------------------------

model SalaryDeduction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  year   Int
  month  Int // 1-12
  amount Float // 扣款金額
  reason String // 扣薪原因

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, year, month])
}

// ---------------------------------------------------------------------------
// 模組五：基礎設定 - 每月收入單價設定
// ---------------------------------------------------------------------------

model MonthlyPricing {
  id                    String @id @default(cuid())
  year                  Int
  month                 Int // 1-12
  forwardPriceBeforeTax Float // 正物流每件稅前單價
  reversePriceBeforeTax Float // 逆物流每件稅前單價
  // 稅後單價由應用層依固定公式計算：
  //   正物流稅後 = 稅前 * 0.96
  //   逆物流稅後 = 稅前 * 0.96

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, month])
}

// ---------------------------------------------------------------------------
// 功能1：首頁公告欄（單一公告，最新覆蓋舊的，id 固定為 1）
// ---------------------------------------------------------------------------

model Announcement {
  id        Int      @id @default(1)
  content   String   @default("")
  updatedBy String? // 最後更新者姓名
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// 功能1：行事曆 - 公司活動／重要日期（由 ADMIN/MANAGER 新增）
// ---------------------------------------------------------------------------

model CalendarEvent {
  id        String   @id @default(cuid())
  date      DateTime
  title     String
  createdBy String // 建立者姓名

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

// ---------------------------------------------------------------------------
// 功能2：員工請假申請與審核
// ---------------------------------------------------------------------------

model LeaveRequest {
  id     String      @id @default(cuid())
  userId String
  user   User        @relation(fields: [userId], references: [id])
  date   DateTime // 請假日期
  reason String? // 原因（選填）
  status LeaveStatus @default(PENDING)

  reviewedBy String? // 審核人 userId
  reviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([date])
}

// ---------------------------------------------------------------------------
// 區域主管系統：區域與區域成員
// ---------------------------------------------------------------------------

model Region {
  id          String  @id @default(cuid())
  name        String // 區域名稱，例如「北區」、「南區」
  description String? // 備註說明
  isActive    Boolean @default(true) // 軟刪除：停用區域但保留成員紀錄

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   RegionMember[]
  schedules Schedule[]
}

model RegionMember {
  id        String  @id @default(cuid())
  regionId  String
  region    Region  @relation(fields: [regionId], references: [id])
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  isManager Boolean @default(false) // true = 此人是該區域的區域經理

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([regionId, userId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// 薪資計算公式設定 (singleton, id 固定為 1)
// ---------------------------------------------------------------------------

model SalaryFormulaSettings {
  id        Int      @id @default(1)
  config    Json // 完整公式設定 JSON（職稱判定門檻、單價、激勵獎金條件、公式說明）
  updatedAt DateTime @updatedAt
  updatedBy String? // 最後修改者 User.id
}

// ---------------------------------------------------------------------------
// 薪資封存：某月份結算後鎖定，凍結當下計算結果
// ---------------------------------------------------------------------------

// 月份封存鎖：存在即代表該年月薪資已封存，讀取改以 SalarySnapshot 為準
model SalaryMonthLock {
  year       Int
  month      Int
  lockedAt   DateTime  @default(now()) // 封存（或重新封存）時間
  lockedById String? // 執行封存的 User.id
  note       String? // 封存備註（選填）
  updatedAt  DateTime  @updatedAt

  @@id([year, month])
}

// 薪資快照：封存當下，每位員工完整的薪資計算結果（EmployeeMonthlySalary JSON）
// 封存後薪資頁/薪資單/我的薪資一律改讀此快照，不再受日後資料補登或公式變動影響
model SalarySnapshot {
  id     String @id @default(cuid())
  userId String // 對應 User.id（不設 FK，封存結果獨立保存）
  year   Int
  month  Int
  data   Json // 完整 EmployeeMonthlySalary 快照

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, year, month])
  @@index([year, month])
}

// ---------------------------------------------------------------------------
// 模組四：貨運行 Excel 對帳
// ---------------------------------------------------------------------------

model ReconciliationRecord {
  id             String @id @default(cuid())
  year           Int
  month          Int
  sourceFileName String

  // 自貨運行月結 Excel「總表」工作表解析出的資料
  excelForwardCount     Int   @default(0) // 正物流總合計件數
  excelReverseCount     Int   @default(0) // 逆物流總合計件數
  excelRevenueBeforeTax Float @default(0) // 運費收入(淨額)總計，未稅

  // 系統內員工自行記錄的送件件數加總（建立對帳時的快照）
  systemForwardCount     Int   @default(0)
  systemReverseCount     Int   @default(0)
  systemRevenueBeforeTax Float @default(0) // 依系統送件件數 * 當月正/逆物流稅前單價計算

  // 差異 = 貨運行 - 系統
  forwardCountDifference Int   @default(0)
  reverseCountDifference Int   @default(0)
  revenueDifference      Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, month])
}

// ---------------------------------------------------------------------------
// 排班系統
// ---------------------------------------------------------------------------

model Schedule {
  id      String   @id @default(cuid())
  date    DateTime // 排班日期（00:00:00 UTC）
  subArea String // 小區域名稱（彈性文字輸入）
  note    String? // 備註（選填）

  employeeId String
  employee   User   @relation("ScheduleEmployee", fields: [employeeId], references: [id])

  regionId String? // 關聯區域（選填，方便 REGION_MANAGER 過濾）
  region   Region? @relation(fields: [regionId], references: [id])

  createdById String
  createdBy   User   @relation("ScheduleCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([employeeId])
  @@index([regionId])
}

// ---------------------------------------------------------------------------
// 加油回報系統
// ---------------------------------------------------------------------------

model FuelReport {
  id     String           @id @default(cuid())
  date   DateTime // 加油日期
  amount Float // 加油金額
  note   String? // 備註（選填）
  status FuelReportStatus @default(PENDING)

  employeeId String
  employee   User   @relation("FuelReportEmployee", fields: [employeeId], references: [id])

  vehicleId String? // 關聯機車車輛（選填）
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  reviewedById String?
  reviewedBy   User?     @relation("FuelReportReviewer", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?

  rejectReason String? // 駁回原因（選填）

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([date])
  @@index([status])
  @@index([vehicleId])
}

// ---------------------------------------------------------------------------
// 停車費回報系統
// ---------------------------------------------------------------------------

model ParkingFeeReport {
  id     String                 @id @default(cuid())
  date   DateTime // 停車日期
  amount Float // 停車費金額
  note   String? // 備註（選填）
  status ParkingFeeReportStatus @default(PENDING)

  employeeId String
  employee   User   @relation("ParkingFeeReportEmployee", fields: [employeeId], references: [id])

  vehicleId String? // 關聯車輛機車或貨車（選填）
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  reviewedById String?
  reviewedBy   User?     @relation("ParkingFeeReportReviewer", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?

  rejectReason String? // 駁回原因（選填）

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([date])
  @@index([status])
  @@index([vehicleId])
}
